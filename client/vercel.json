{
  "version": 2,
  "rewrites": [
    {
      "source": "/uploads/(.*)",
      "destination": "https://anle-server.vercel.app/api/v1/f/uploads/$1"
    },
    {
      "source": "/avatars/(.*)",
      "destination": "https://anle-server.vercel.app/api/v1/f/avatars/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}